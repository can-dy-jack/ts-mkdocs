{
  "name": "ts-mkdocs-root",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "example:build": "node packages/core/dist/cli.js build -f example/ts-mkdocs.yml",
    "example:serve": "node packages/core/dist/cli.js serve -f example/ts-mkdocs.yml",
    "start": "node packages/core/dist/cli.js serve -f example/ts-mkdocs.yml"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "glightbox": "^3.3.1"
  }
}
